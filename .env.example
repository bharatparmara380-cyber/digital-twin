# ─────────────────────────────────────────────
#  .env.example  →  Copy this to a file named `.env`
#  and fill in your real keys.
# ─────────────────────────────────────────────

# 1. Get your FREE Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# 2. Your name — the agent will introduce itself as you
YOUR_NAME=Your Full Name

# 3. (Optional) A one-line tagline the agent uses to introduce itself
YOUR_TAGLINE=Software Engineer | AI Enthusiast | Problem Solver
